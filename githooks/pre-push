#!/bin/sh
set -eu

# Escape hatch: `SKIP_PREFLIGHT=1 git push` bypasses the hook entirely.
# Documented path for headless/CI pushes where the full preflight cannot run.
if [ "${SKIP_PREFLIGHT:-0}" = "1" ]; then
  echo "githook(pre-push): SKIP_PREFLIGHT=1 — skipping preflight checks"
  exit 0
fi

# Headless detection: no controlling TTY, CI flag, or no X display (Linux).
# In that case the Playwright e2e step hangs (no browser/ports), so skip just
# e2e and keep the rest of preflight. Interactive local pushes run the full set.
PREFLIGHT_ENV=""
if [ ! -t 1 ] || [ -n "${CI:-}" ] || { [ "$(uname -s)" = "Linux" ] && [ -z "${DISPLAY:-}" ]; }; then
  echo "githook(pre-push): headless environment detected — running preflight without e2e (set SKIP_PREFLIGHT=1 to bypass entirely)"
  PREFLIGHT_ENV="PREFLIGHT_SKIP_E2E=1"
fi

if upstream=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null); then
  echo "githook(pre-push): npm run check:preflight -- --base-ref $upstream"
  env $PREFLIGHT_ENV npm run check:preflight -- --base-ref "$upstream"
else
  echo "githook(pre-push): npm run check:preflight"
  env $PREFLIGHT_ENV npm run check:preflight
fi
