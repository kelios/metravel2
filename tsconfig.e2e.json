{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "e2e/**/*.ts",
    "types/**/*.d.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules/**/*",
    "coverage/**/*",
    "dist/**/*",
    "playwright-report/**/*",
    "test-results/**/*"
  ]
}
