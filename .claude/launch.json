{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web"],
      "port": 8081,
      "autoPort": false
    },
    {
      "name": "Expo Web 8082",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "8082"],
      "port": 8082,
      "autoPort": false
    },
    {
      "name": "Expo Start (All Platforms)",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["start"],
      "port": 8081,
      "autoPort": false
    },
    {
      "name": "E2E Web Server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["scripts/e2e-webserver.js"],
      "port": 8085
    },
    {
      "name": "Workboard Static",
      "runtimeExecutable": "node",
      "runtimeArgs": ["scripts/workboard-server.js", "4599"],
      "port": 4599,
      "autoPort": false
    },
    {
      "name": "Dist Static",
      "runtimeExecutable": "node",
      "runtimeArgs": [".claude/dist-server.js", "4601"],
      "port": 4601,
      "autoPort": false
    },
    {
      "name": "Prod Static",
      "runtimeExecutable": "node",
      "runtimeArgs": [".claude/prod-server.js", "8081"],
      "port": 8081,
      "autoPort": false
    }
  ]
}
