{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web"],
      "port": 8081,
      "autoPort": false
    },
    {
      "name": "Expo Web 8082",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["./node_modules/.bin/expo", "start", "--web", "--port", "8082"],
      "port": 8082,
      "autoPort": false
    },
    {
      "name": "Expo Start (All Platforms)",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["start"],
      "port": 8081,
      "autoPort": false
    },
    {
      "name": "E2E Web Server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["scripts/e2e-webserver.js"],
      "port": 8085
    }
  ]
}
